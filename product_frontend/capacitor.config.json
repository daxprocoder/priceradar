{
  "appId": "com.priceradar.app",
  "appName": "PriceRadar",
  "webDir": "dist",
  "server": {
    "cleartext": true,
    "androidScheme": "http"
  },
  "android": {
    "backgroundColor": "#000000"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 500,
      "launchFadeOutDuration": 500,
      "launchAutoHide": true,
      "backgroundColor": "#000000",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_INSIDE",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK"
    }
  }
}